# Copy to .env and fill in values (never commit .env)

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://

# Secret for signing session cookies (required in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Set to "production" to enable secure (HTTPS-only) cookies
NODE_ENV=local

# HTTP port (default: 3000)
# PORT=9090

# Web Push (daily reminder). Leave unset to disable push reminders entirely.
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL required by the Web Push protocol (any mailto: works)
VAPID_SUBJECT=mailto:you@example.com

# HH:MM (24h, server-local time) when the daily reminder fires. Default: 20:00
# REMINDER_TIME=20:00

PNPM_PATH=